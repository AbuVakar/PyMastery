# PyMastery Production Secrets Template
# Copy this file to .env.secrets and update with your actual production values
# NEVER commit this file to version control

# =============================================================================
# DATABASE SECRETS
# =============================================================================
MONGODB_URL=mongodb://username:strong_password@localhost:27017/pymastery?authSource=admin
MONGODB_USERNAME=admin
MONGODB_PASSWORD=your_strong_mongodb_password

# Redis Configuration
REDIS_URL=redis://username:password@localhost:6379/0
REDIS_PASSWORD=your_strong_redis_password

# =============================================================================
# SECURITY SECRETS
# =============================================================================
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-min-32-characters-long
JWT_REFRESH_SECRET_KEY=your-super-secure-refresh-secret-key-min-32-characters-long

# =============================================================================
# EXTERNAL API SECRETS
# =============================================================================
# Judge0 Code Execution
JUDGE0_API_KEY=your-rapidapi-key-here

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API
GROQ_API_KEY=your-groq-api-key-here

# HuggingFace Token
HUGGINGFACE_TOKEN=your-huggingface-token-here

# =============================================================================
# EMAIL CONFIGURATION SECRETS
# =============================================================================
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# =============================================================================
# PAYMENT PROCESSING SECRETS
# =============================================================================
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================
# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your-email@example.com

# Sentry Error Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Google Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Prometheus
PROMETHEUS_USERNAME=your-prometheus-username
PROMETHEUS_PASSWORD=your-prometheus-password

# Grafana
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password

# =============================================================================
# CLOUD SERVICES
# =============================================================================
# AWS (if using AWS services)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# DigitalOcean (if using DO services)
DIGITALOCEAN_TOKEN=your-digitalocean-token

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# SSL CERTIFICATES (Production)
# =============================================================================
# Note: These should be actual certificate files, not just paths
# SSL_CERT_PATH=./ssl/cert.pem
# SSL_KEY_PATH=./ssl/key.pem

# =============================================================================
# ENCRYPTION KEYS
# =============================================================================
# Data encryption key (32 characters minimum)
DATA_ENCRYPTION_KEY=your-32-character-encryption-key-here

# File encryption key
FILE_ENCRYPTION_KEY=your-file-encryption-key-here

# =============================================================================
# WEBHOOK SECRETS
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# =============================================================================
# BACKUP SERVICES
# =============================================================================
# AWS S3 Backup
AWS_S3_BUCKET=your-backup-bucket-name
AWS_S3_ACCESS_KEY=your-s3-access-key
AWS_S3_SECRET_KEY=your-s3-secret-key

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# Set to "true" to override production settings for development
DEVELOPMENT_OVERRIDE=false

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. Never commit this file to version control
# 2. Use strong, unique passwords (minimum 32 characters)
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use environment-specific secrets (dev/staging/prod)
# 5. Enable 2FA on all external services
# 6. Use IP whitelisting where possible
# 7. Monitor for unauthorized access
# 8. Have a secrets rotation strategy
