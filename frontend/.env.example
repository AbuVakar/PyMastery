# Development Environment Configuration for PyMastery Frontend
# Copy this file to .env and update with your values

# =============================================================================
# API CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_API_TIMEOUT=30000

# =============================================================================
# ENVIRONMENT
# =============================================================================
VITE_NODE_ENV=development
VITE_ENVIRONMENT=development

# =============================================================================
# AI SERVICES (Optional - will use fallback if not set)
# =============================================================================
# Get your Groq API key from: https://console.groq.com/
VITE_GROQ_API_KEY=your-groq-api-key-here

# Get your OpenAI API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_OPENAI_MODEL=gpt-3.5-turbo

# Get your Google Gemini API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# FEATURES
# =============================================================================
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_CODE_EXECUTION=true
VITE_ENABLE_AI_ASSISTANT=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
VITE_DEV_MODE=true
VITE_ENABLE_DEBUG=true
VITE_ENABLE_LOGGING=true
VITE_ENABLE_MOCK_API=false

# =============================================================================
# AUTHENTICATION
# =============================================================================
VITE_ENABLE_AUTH=true
VITE_AUTH_PROVIDER=jwt
VITE_TOKEN_REFRESH_INTERVAL=25
VITE_SESSION_TIMEOUT=3600
