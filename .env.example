# PyMastery Environment Variables Template
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
MONGODB_URL=mongodb://localhost:27017/pymastery
MONGODB_DB_NAME=pymastery
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password123

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-here-change-in-production
ENVIRONMENT=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =============================================================================
# JUDGE0 CODE EXECUTION (Optional)
# =============================================================================
# Get your RapidAPI key from: https://rapidapi.com/judge0-ce/api/judge0-ce
JUDGE0_API_KEY=your-rapidapi-key-here
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com/submissions
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# =============================================================================
# OPENAI API (Optional)
# =============================================================================
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_ENABLED=false

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
COMPRESSION_ENABLED=true
TRACK_RESPONSE_TIMES=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true

# =============================================================================
# SSL/TLS CONFIGURATION (Production)
# =============================================================================
SSL_ENABLED=false
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# =============================================================================
# MONITORING & ALERTS
# =============================================================================
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
MONITORING_ENABLED=true

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@pymastery.com

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_TIMEOUT=3600
REFRESH_TOKEN_EXPIRY=604800

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG_MODE=true
CORS_CREDENTIALS=true
CORS_ALLOW_ALL_ORIGINS=true
ENABLE_CORS_DEBUG=true
LOG_REQUESTS=true
ENABLE_API_DOCS=true

# =============================================================================
# PRODUCTION SETTINGS (Uncomment for production)
# =============================================================================
# ENVIRONMENT=production
# DEBUG_MODE=false
# LOG_LEVEL=WARNING
# CORS_ALLOW_ALL_ORIGINS=false
# ENABLE_CORS_DEBUG=false
# LOG_REQUESTS=false
