# PyMastery consolidated environment reference
# Copy backend values into backend/.env
# Copy frontend values into frontend/.env

# ---------------------------------------------------------------------------
# Backend required
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=<generate-a-strong-random-secret-at-least-32-characters>
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=pymastery

# ---------------------------------------------------------------------------
# Backend app configuration
# ---------------------------------------------------------------------------
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
FRONTEND_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# ---------------------------------------------------------------------------
# Email / contact
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=<your-smtp-password>
EMAIL_FROM=noreply@pymastery.com
SUPPORT_EMAIL=support@pymastery.com

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

# ---------------------------------------------------------------------------
# Gemini AI
# ---------------------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Judge0 code execution
# ---------------------------------------------------------------------------
JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=
JUDGE0_HOST=
ALLOW_LOCAL_CODE_EXECUTION_FALLBACK=false

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://127.0.0.1:8000
VITE_FRONTEND_URL=http://127.0.0.1:5173
VITE_WS_URL=ws://127.0.0.1:8000
